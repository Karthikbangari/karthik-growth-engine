# Copy this file to ".env" (which is git-ignored) and paste your real key.
# Get a key at https://console.anthropic.com  (Settings → API Keys).
# Used ONLY by the serverless function in /api/generate.js — never the browser.
#
# Local testing: run `vercel dev` (not `npm run dev`) so the /api route works.
# Production: set this same variable in Vercel → Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-your-key-here
